# syntax=docker/dockerfile:1
# App de residentes en web (Flutter → nginx)
#
#   docker build -f Dockerfile.web -t conjunapp-app-web \
#     --build-arg API_BASE_URL=http://localhost:8000/api/v1 .

FROM ghcr.io/cirruslabs/flutter:stable AS build

WORKDIR /app

# Dependencias primero para cachear la capa
COPY pubspec.yaml pubspec.lock ./
RUN flutter config --enable-web \
    && flutter pub get

COPY . .

ARG API_BASE_URL=http://localhost:8000/api/v1
ENV API_BASE_URL=$API_BASE_URL

RUN flutter build web --release --dart-define=API_BASE_URL=${API_BASE_URL}

FROM nginx:1.27-alpine AS production

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build/web /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=5 \
  CMD wget -qO- http://127.0.0.1/health >/dev/null || exit 1

CMD ["nginx", "-g", "daemon off;"]

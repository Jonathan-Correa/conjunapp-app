# Configuración de la app Flutter (no usa flutter_dotenv).
# Pasa el valor con --dart-define al ejecutar o compilar.
#
# Emulador Android → host Docker/local:
#   API_BASE_URL=http://10.0.2.2:8000/api/v1
#
# iOS simulador / desktop (mismo host):
#   API_BASE_URL=http://localhost:8000/api/v1
#
# Dispositivo físico (misma red):
#   API_BASE_URL=http://<IP-LAN>:8000/api/v1

API_BASE_URL=http://localhost:8000/api/v1
